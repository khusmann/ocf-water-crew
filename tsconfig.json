{
  "compilerOptions": {
    "strict": true,
    "target": "ES2019",
    "lib": ["ES2019"],
    "module": "ES2020",
    "moduleResolution": "bundler",
    "outDir": "./build",
    "types": ["google-apps-script"],
    "removeComments": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/**/*.ts"]
}
